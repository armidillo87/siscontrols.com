---
interface Props {
  title?: string;
  subtitle?: string;
  steps: {
    title: string;
    description: string;
  }[];
}

const { 
  title = "Our Simple Process", 
  subtitle = "How we go from first call to final completion",
  steps = [] 
} = Astro.props;
---

<section class="process-walkthrough section">
  <div class="container">
    <div class="section-header text-center">
      <h2>{title}</h2>
      <p class="subtitle">{subtitle}</p>
    </div>
    
    <div class="process-grid">
      {steps.map((step, index) => (
        <div class="process-step">
          <div class="step-number">{index + 1}</div>
          <div class="step-content">
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-walkthrough {
    padding: 5rem 0;
    background: #fff;
  }
  
  .section-header {
    margin-bottom: 4rem;
  }
  
  .process-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem 2rem;
    position: relative;
  }
  
  /* The connecting line on desktop */
  @media (min-width: 900px) {
    .process-grid::before {
      content: '';
      position: absolute;
      top: 30px; /* Half of circle height */
      left: 0;
      width: 100%;
      height: 2px;
      background: var(--color-border, #eee);
      z-index: 1;
    }
  }

  @media (max-width: 899px) {
    .process-grid {
      grid-template-columns: 1fr;
    }
  }
  
  .process-step {
    position: relative;
    z-index: 2;
    text-align: center;
  }
  
  .step-number {
    width: 60px;
    height: 60px;
    background: #fff;
    border: 3px solid var(--color-accent, #d4af37);
    color: var(--color-dark, #1a1a1a);
    font-size: 1.5rem;
    font-weight: bold;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    font-family: var(--font-display, sans-serif);
    box-shadow: 0 0 0 10px #fff; /* to break the connecting line */
  }
  
  .step-content h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-display, sans-serif);
  }
  
  .step-content p {
    color: var(--color-text-mid, #555);
    line-height: 1.5;
    font-size: 0.95rem;
  }
</style>
