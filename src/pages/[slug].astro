---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import BlockRenderer from '@/components/BlockRenderer.astro';
import { getProjectConfig } from '../utils/twenty';

// 1. Generate static paths for all JSON files in src/data/pages
export async function getStaticPaths() {
  const pages = import.meta.glob('@/data/pages/*.json', { eager: true });
  
  return Object.values(pages).map((page: any) => {
    // Exclude home.json because index.astro handles the root route
    if (page.default.slug === 'index') return { params: { slug: undefined }, props: { page: page.default } };
    
    return {
      params: { slug: page.default.slug },
      props: { page: page.default },
    };
  }).filter(route => route.params.slug !== undefined); // filter out index if it returns undefined
}

const { page } = Astro.props;
const siteConfig = await getProjectConfig('siscontrols');
const { business } = siteConfig;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": business.name,
  "telephone": `+1${business.phoneClean}`,
  "email": business.email,
  "url": business.url,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": business.address.street,
    "addressLocality": business.address.city,
    "addressRegion": business.address.stateAbbr,
    "postalCode": business.address.zip,
    "addressCountry": business.address.country
  },
  "geo": { "@type": "GeoCoordinates", "latitude": business.geo.lat, "longitude": business.geo.lng },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": business.rating,
    "reviewCount": business.reviewCount,
    "bestRating": "5"
  },
  "priceRange": "$$"
};
---

<BaseLayout title={`${page.title || business.name} | ${business.tagline}`} description={page.description || business.description} schema={schema}>
  <Header slot="header" />

  <BlockRenderer blocks={page.blocks || []} />

  <Footer slot="footer" />
</BaseLayout>
