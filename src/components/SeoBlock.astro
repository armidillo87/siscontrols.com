---
interface Props {
  heading?: string;
  subheading?: string;
  content: string;
}

const { 
  heading = "About Our Services",
  subheading = "",
  content
} = Astro.props;
---

<section class="seo-block section section--cream">
  <div class="container">
    <div class="seo-content-wrapper">
      {heading && <h2>{heading}</h2>}
      {subheading && <h3 class="subtitle">{subheading}</h3>}
      <div class="seo-rich-content" set:html={content} />
    </div>
  </div>
</section>

<style>
  .seo-block {
    padding: 6rem 0;
  }
  
  .seo-content-wrapper {
    max-width: 900px;
    margin: 0 auto;
    background: #fff;
    padding: 4rem;
    border-radius: var(--radius-md, 14px);
    box-shadow: 0 10px 40px rgba(0,0,0,0.03);
    border-top: 4px solid var(--color-accent, #d4af37);
  }

  .seo-content-wrapper h2 {
    font-size: clamp(2rem, 3vw, 2.5rem);
    margin-bottom: 0.5rem;
    color: var(--color-dark, #1a1a1a);
  }

  .seo-content-wrapper .subtitle {
    font-size: 1.25rem;
    color: var(--color-text-mid, #555);
    margin-bottom: 2.5rem;
    font-weight: 500;
  }

  .seo-rich-content :global(h2),
  .seo-rich-content :global(h3),
  .seo-rich-content :global(h4) {
    font-family: var(--font-heading, sans-serif);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-dark, #1a1a1a);
  }

  .seo-rich-content :global(h3) {
    font-size: 1.5rem;
  }

  .seo-rich-content :global(p) {
    margin-bottom: 1.5rem;
    color: var(--color-text-mid, #555);
    line-height: 1.8;
  }

  .seo-rich-content :global(ul), 
  .seo-rich-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: var(--color-text-mid, #555);
  }

  .seo-rich-content :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .seo-rich-content :global(strong) {
    color: var(--color-dark, #1a1a1a);
  }

  @media (max-width: 768px) {
    .seo-content-wrapper {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
