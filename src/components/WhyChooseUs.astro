---
interface Props {
  title?: string;
  subtitle?: string;
  reasons: {
    icon: string;
    headline: string;
    description: string;
  }[];
}

const { 
  title = "Why Choose Us", 
  subtitle = "What sets us apart from the competition",
  reasons = [] 
} = Astro.props;
---

<section class="why-choose-us section">
  <div class="container">
    <div class="section-header text-center">
      <h2>{title}</h2>
      <p class="subtitle">{subtitle}</p>
    </div>
    
    <div class="why-grid">
      {reasons.map(reason => (
        <div class="why-card">
          <div class="why-icon">
            {reason.icon === 'check' && <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 32px; height: 32px;"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>}
            {reason.icon === 'clock' && <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 32px; height: 32px;"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>}
            {reason.icon === 'shield' && <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 32px; height: 32px;"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>}
            {reason.icon === 'user' && <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 32px; height: 32px;"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>}
            {reason.icon === 'star' && <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" style="width: 32px; height: 32px;"><path d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" /></svg>}
            {reason.icon === 'zap' && <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width: 32px; height: 32px;"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>}
          </div>
          <h3>{reason.headline}</h3>
          <p>{reason.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .why-choose-us {
    background-color: var(--color-bg-alt, #f9f9f9);
    padding: 5rem 0;
  }
  
  .section-header {
    margin-bottom: 3rem;
  }
  
  .subtitle {
    font-size: 1.125rem;
    color: var(--color-text-light, #666);
    max-width: 600px;
    margin: 0 auto;
  }
  
  .why-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  @media (max-width: 1024px) {
    .why-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .why-grid {
      grid-template-columns: 1fr;
    }
  }
  
  .why-card {
    background: #fff;
    padding: 2.5rem 2rem;
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    text-align: center;
    transition: transform 0.3s ease;
    border-top: 4px solid var(--color-accent, #d4af37);
  }
  
  .why-card:hover {
    transform: translateY(-5px);
  }
  
  .why-icon {
    width: 60px;
    height: 60px;
    margin: 0 auto 1.5rem;
    background: rgba(212, 175, 55, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    color: var(--color-accent, #d4af37);
  }
  
  .why-card h3 {
    margin-bottom: 1rem;
    font-size: 1.25rem;
    font-family: var(--font-display, sans-serif);
    color: var(--text-dark, #2b2b2b);
  }
  
  .why-card p {
    color: var(--color-text-mid, #555);
    line-height: 1.6;
    font-size: 0.95rem;
  }
</style>
